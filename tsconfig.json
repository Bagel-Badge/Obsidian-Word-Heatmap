{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"paths": {
			"src/*": ["src/*"]
		},
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2021"]
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "obsidian-contribution-graph-ref"]
}
