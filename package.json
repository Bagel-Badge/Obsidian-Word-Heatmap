{
	"name": "obsidian-word-heatmap",
	"version": "0.1.1",
	"description": "Obsidian 中文字数热力图插件，统计每日写作字数并以 GitHub 风格热力图展示",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": ["obsidian", "plugin", "heatmap", "chinese", "word-count"],
	"author": "",
	"license": "Apache-2.0",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"luxon": "^3.4.4",
		"@types/luxon": "^3.3.7"
	}
}
